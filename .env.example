# Shopify
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01
SHOPIFY_LOCATION_ID=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders,write_orders,read_draft_orders,write_draft_orders

# Allegro
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_REDIRECT_URI=http://localhost:3001/auth/allegro/callback
# VPS: https://yourdomain.com/auth/allegro/callback
ALLEGRO_API_BASE=https://api.allegro.pl
ALLEGRO_AUTH_URL=https://allegro.pl/auth/oauth
ALLEGRO_SANDBOX=false

# Sync Settings
PRICE_MULTIPLIER=1.15
PRICE_OFFSET=0
PRICE_ROUND=true

# App
PORT=3001
APP_URL=http://localhost:3001
# VPS: https://yourdomain.com
LOG_LEVEL=info
