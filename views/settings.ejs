<%- include('partials/header') %>

<h1>Настройки</h1>

<div class="settings-grid">
  <div class="settings-section">
    <h2>Подключения</h2>

    <div class="setting-item">
      <div class="setting-label">Shopify магазин</div>
      <div class="setting-value"><%= shopifyStore %></div>
    </div>

    <div class="setting-item">
      <div class="setting-label">Allegro</div>
      <div class="setting-value">
        <% if (isAllegroConnected) { %>
          <span class="status-ok">Подключено</span>
          <span class="text-muted">Токен истекает: <%= tokenExpiresAt %></span>
        <% } else { %>
          <span class="status-error">Не подключено</span>
        <% } %>
      </div>
      <div class="setting-action">
        <a href="/auth/allegro" class="btn btn-sm"><%= isAllegroConnected ? 'Переподключить' : 'Подключить Allegro' %></a>
      </div>
    </div>
  </div>
